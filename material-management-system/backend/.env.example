NODE_ENV=development
PORT=3000
# MongoDB 连接字符串
MONGODB_URI=mongodb://localhost:27017/dam
# JWT 密钥，生产环境请使用至少 64 位随机字符串
JWT_SECRET=your_secret_key_here_use_at_least_64_random_chars
# 上传文件存储目录（相对或绝对路径）
UPLOAD_DIR=uploads
# 允许跨域的前端地址（多个用逗号分隔）
CORS_ORIGIN=http://localhost:5173
# 日志级别：error | warn | info | http | debug
LOG_LEVEL=info
